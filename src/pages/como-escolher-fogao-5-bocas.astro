---
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedContent from '../components/RelatedContent.astro';
import SmartRecommendations from '../components/SmartRecommendations.astro';
import EditorialTrustRibbon from '../components/EditorialTrustRibbon.astro';
import { produtos } from '../data/products';
import { PRODUCT_IMAGE_REVIEW } from '../data/productImages';

const site = Astro.site ?? new URL('https://casapraticaeletro.com.br');
const canonical = new URL('/como-escolher-fogao-5-bocas', site).href;
const pageTitle = 'Como escolher fogão 5 bocas em 2026 | Casa Prática Eletro';
const description =
	'Guia da Casa Prática Eletro para escolher fogão 5 bocas: medidas, gás, forno, segurança e comparativos práticos.';
const ogImage = new URL(PRODUCT_IMAGE_REVIEW.brastemp.replace(/^\//, ''), site).href;
---

<BaseLayout
	title={pageTitle}
	description={description}
	canonical={canonical}
	openGraph={{
		title: pageTitle,
		description,
		url: canonical,
		type: 'article',
		image: ogImage,
		imageAlt: 'Fogão 5 bocas em inox — referência visual do guia prático',
	}}
>
	<article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<p class="text-xs font-bold uppercase tracking-[0.35em] text-pop">Guia prático</p>
		<h1 class="font-display mt-4 text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl">Como escolher fogão 5 bocas</h1>
		<p class="mt-4 text-lg leading-relaxed text-on-ink-body">
			Use este guia quando já estiver decidido por <strong class="text-on-ink-body">melhores fogões 5 bocas</strong>, mas ainda travado
			em medida, tipo de instalação ou versão do forno.
		</p>
		<div class="mt-8">
			<EditorialTrustRibbon />
		</div>
		<div class="mt-10 space-y-8 text-base leading-relaxed text-on-ink-body">
			<section aria-labelledby="step1">
				<h2 id="step1" class="font-display text-xl font-bold text-on-ink-body">1. Desenhe a cozinha em números</h2>
				<p class="mt-3">
					Largura total, profundidade útil, altura do móvel ao lado e espaço da porta do forno (abertura completa). Sem isso,
					o “melhor” vira troca e estresse.
				</p>
			</section>
			<section aria-labelledby="step2">
				<h2 id="step2" class="font-display text-xl font-bold text-on-ink-body">2. Gás e ventilação</h2>
				<p class="mt-3">
					Confirme GLP vs rede e regras do condomínio. Em dúvida, profissional credenciado vale mais que qualquer review.
				</p>
			</section>
			<section aria-labelledby="step3">
				<h2 id="step3" class="font-display text-xl font-bold text-on-ink-body">3. Cruze com comparativos</h2>
				<p class="mt-3">
					Depois dessas dicas, volte à{' '}
					<a href="/" class="link-accent" aria-label="Lista de fogões 5 bocas na página inicial">
						lista na página inicial
					</a>
					, ao{' '}
					<a
						href="/comparativo-fogao-4-vs-5-bocas"
						class="link-accent"
						aria-label="Comparativo entre fogão 4 bocas e fogão 5 bocas"
					>
						4 vs 5 bocas
					</a>{' '}
					e ao{' '}
					<a
						href="/fogao-5-bocas-custo-beneficio"
						class="link-accent"
						aria-label="Guia fogão 5 bocas custo-benefício"
					>
						custo-benefício
					</a>
					.
				</p>
			</section>
		</div>
		<div class="mt-12 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:gap-4">
			<a
				href={produtos.brastempBFS5NCR.ml}
				class="inline-flex min-h-[52px] flex-1 items-center justify-center bg-cta px-8 text-xs font-bold uppercase tracking-wider text-white ring-1 ring-white/15 transition hover:bg-cta-hover sm:min-w-[200px]"
				target="_blank"
				rel="nofollow sponsored noopener noreferrer"
				aria-label="Ver preço atualizado de fogões 5 bocas na loja parceira — abre em nova aba (link patrocinado)"
			>
				Ver preço atualizado
			</a>
			<a href="/melhor-fogao-5-bocas" class="btn-secondary-premium flex-1 px-8 sm:min-w-[200px]">Abrir guia mestre 5 bocas</a>
		</div>
		<RelatedContent
			class="mt-14"
			currentPath="/como-escolher-fogao-5-bocas"
			eyebrow="Veja também"
			title="Leituras relacionadas"
			subtitle="Comparativos e leituras editoriais para alinhar layout e custo-benefício antes de fechar."
		/>

		<SmartRecommendations
			class="mt-12"
			currentPath="/como-escolher-fogao-5-bocas"
			heading="Próximos passos editoriais"
		/>
	</article>
</BaseLayout>
