---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogGrid from '../components/BlogGrid.astro';
import { PRODUCT_IMAGE_REVIEW } from '../data/productImages';

const site = Astro.site ?? new URL('https://casapraticaeletro.com.br');
const canonical = new URL(Astro.url.pathname, site).href;
const pageTitle = 'Blog de Eletrodomésticos | Casa Prática Eletro';
const description =
	'Casa Prática Eletro: artigos, reviews e comparativos de eletrodomésticos para ajudar você a comprar melhor.';
const ogImage = new URL(PRODUCT_IMAGE_REVIEW.brastemp.replace(/^\//, ''), site).href;

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
	title={pageTitle}
	description={description}
	canonical={canonical}
	openGraph={{
		title: pageTitle,
		description,
		url: canonical,
		type: 'website',
		image: ogImage,
		imageAlt: 'Fogão 5 bocas em inox — ilustração editorial do blog Casa Prática Eletro',
	}}
>
	<header class="mx-auto max-w-7xl px-4 pt-12 sm:px-6 lg:px-8">
		<h1 class="font-display text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl">Blog</h1>
		<p class="mt-3 max-w-2xl text-on-ink-body">
			Análises e comparativos em texto. Para editar posts e links de compra, use os arquivos Markdown dos artigos no projeto.
		</p>
	</header>
	<BlogGrid
		variant="dark"
		posts={posts}
		title="Todos os artigos"
		subtitle="Clique em um card para ler o artigo completo — conteúdo pensado para fechar lacunas que a ficha do produto não mostra."
		showViewAllLink={false}
	/>
</BaseLayout>
