---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import EditorialLinks from '../../components/EditorialLinks.astro';
import SmartRecommendations from '../../components/SmartRecommendations.astro';
import EditorialTrustRibbon from '../../components/EditorialTrustRibbon.astro';
import { getCollection, render } from 'astro:content';
import { PRODUCT_IMAGE_REVIEW } from '../../data/productImages';
import { getBlogThumbnailAsset } from '../../data/blogThumbnailAssets';
import { getImage, Picture } from 'astro:assets';
import mesaVidroArticleHero from '../../assets/images/blog/reviews/review-fogao-com-mesa-de-vidro-article-hero.png';
import embutirPisoArticleHero from '../../assets/images/blog/guias/guia-fogao-embutir-ou-de-piso-article-hero.png';
import { findEntry, type EditorialEntry } from '../../data/editorialContent';

type ArticleHeroEntry = {
	src: typeof mesaVidroArticleHero;
	alt: string;
	/** Ajuste fino do recorte em `object-fit: cover` (16:10). */
	objectPosition: 'mesa-vidro' | 'center';
	/** Legenda curta abaixo da imagem (estilo artigo). */
	caption?: string;
};

const articleHeroes: Record<string, ArticleHeroEntry> = {
	'review-fogao-com-mesa-de-vidro': {
		src: mesaVidroArticleHero,
		alt: 'Cooktop de quatro bocas com mesa de vidro temperado embutido em bancada escura, cozinha moderna com iluminação quente sob a prateleira.',
		objectPosition: 'mesa-vidro',
	},
	'guia-fogao-embutir-ou-de-piso': {
		src: embutirPisoArticleHero,
		alt: 'Comparação entre fogão de piso com pés e fogão embutido na bancada, ambos em inox com mesa de vidro em cozinha escura.',
		objectPosition: 'center',
		caption:
			'À esquerda, fogão de piso; à direita, fogão embutido na bancada — o mesmo tipo de produto em formatos de instalação diferentes.',
	},
};

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const articleHero = articleHeroes[post.id];

/**
 * Pareamento editorial por slug — escolhe naturalmente:
 *  - artigo cozinha-moderna (mesa de vidro) → review de modelo inox premium
 *  - artigo decoração (embutir/piso)        → análise Brastemp + review Electrolux
 *  - artigo 4 bocas / cozinha moderna       → guia 5 bocas + comparativo direto
 *  - artigo guia 5 bocas                    → análise Brastemp + comparativo
 */
const editorialPairings: Record<string, string[]> = {
	'review-fogao-com-mesa-de-vidro': [
		'/brastemp-bfs5ncr-vale-a-pena',
		'/review-fogao-5-bocas-electrolux',
	],
	'guia-fogao-embutir-ou-de-piso': [
		'/brastemp-bfs5ncr-vale-a-pena',
		'/comparativo-fogao-4-vs-5-bocas',
	],
	'fogao-4-bocas-ainda-vale-a-pena': [
		'/melhor-fogao-5-bocas',
		'/comparativo-fogao-4-vs-5-bocas',
	],
};

const inlinePairingItems: EditorialEntry[] = (editorialPairings[post.id] ?? [])
	.map((href) => findEntry((e) => e.href === href))
	.filter(Boolean) as EditorialEntry[];

const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });

const site = Astro.site ?? new URL('https://casapraticaeletro.com.br');
const canonical = new URL(Astro.url.pathname, site).href;
const faq = post.data.faq;

const thumbMeta = getBlogThumbnailAsset(post.id);
const ogSource = articleHero?.src ?? thumbMeta;
let ogImage: string;
if (ogSource) {
	const og = await getImage({ src: ogSource, width: 1200, format: 'webp' });
	ogImage = og.src.startsWith('http') ? og.src : new URL(og.src.replace(/^\//, ''), site).href;
} else if (post.data.coverImage) {
	ogImage = new URL(String(post.data.coverImage).replace(/^\//, ''), site).href;
} else {
	ogImage = new URL(PRODUCT_IMAGE_REVIEW.brastemp.replace(/^\//, ''), site).href;
}

const orgId = `${site.href}#organization`;
const articleId = `${canonical}#article`;
const webpageId = `${canonical}#webpage`;
const breadcrumbId = `${canonical}#breadcrumb`;
const faqId = `${canonical}#faq`;

const graph: Record<string, unknown>[] = [
	{
		'@type': 'Organization',
		'@id': orgId,
		name: 'Casa Prática Eletro',
		url: site.href,
	},
	{
		'@type': 'BreadcrumbList',
		'@id': breadcrumbId,
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Início', item: site.href },
			{ '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', site).href },
			{ '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
		],
	},
	{
		'@type': 'WebPage',
		'@id': webpageId,
		url: canonical,
		name: `${post.data.title} | Casa Prática Eletro`,
		description: post.data.description,
		mainEntity: { '@id': articleId },
	},
	{
		'@type': 'Article',
		'@id': articleId,
		headline: post.data.title,
		description: post.data.description,
		image: [ogImage],
		author: { '@id': orgId },
		publisher: { '@id': orgId },
		datePublished: post.data.pubDate.toISOString(),
		dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
		mainEntityOfPage: { '@id': webpageId },
		articleSection: post.data.category,
		inLanguage: 'pt-BR',
	},
];
if (faq?.length) {
	graph.push({
		'@type': 'FAQPage',
		'@id': faqId,
		mainEntity: faq.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: { '@type': 'Answer', text: item.answer },
		})),
	});
}
const structuredData = { '@context': 'https://schema.org', '@graph': graph };
---

<BaseLayout
	title={`${post.data.title} | Casa Prática Eletro`}
	description={post.data.description}
	canonical={canonical}
	openGraph={{
		title: `${post.data.title} | Casa Prática Eletro`,
		description: post.data.description,
		url: canonical,
		image: ogImage,
		imageAlt: articleHero?.alt ?? post.data.title,
		type: 'article',
		publishedTime: post.data.pubDate.toISOString(),
		modifiedTime: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
	}}
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(structuredData)} />
	<article class="mx-auto max-w-2xl px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14">
		<Breadcrumbs
			class="mb-8"
			items={[
				{ name: 'Início', href: '/' },
				{ name: 'Blog', href: '/blog' },
				{ name: post.data.title },
			]}
		/>
		<header>
			<p class="text-xs font-bold uppercase tracking-[0.35em] text-pop">
				{post.data.category} · {fmt.format(post.data.pubDate)}
			</p>
			<h1 class="font-display mt-4 text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl lg:text-5xl">
				{post.data.title}
			</h1>
			<p class="mt-4 text-lg leading-relaxed text-on-ink-body">{post.data.description}</p>
		</header>
		<div class="mt-8">
			<EditorialTrustRibbon />
		</div>
		{
			articleHero ? (
				<figure
					class="mt-10 overflow-hidden rounded-2xl shadow-[0_14px_40px_rgba(0,0,0,0.45)] ring-1 ring-white/10"
				>
					<div class="relative aspect-[16/10] w-full overflow-hidden bg-brand-900/40">
						<Picture
							src={articleHero.src}
							alt={articleHero.alt}
							formats={['avif', 'webp']}
							width={articleHero.src.width}
							height={articleHero.src.height}
							widths={[640, 768, 960, 1152]}
							sizes="(max-width: 768px) 100vw, 672px"
							quality={82}
							priority
							class:list={[
								'h-full w-full object-cover',
								articleHero.objectPosition === 'mesa-vidro' ? 'object-[center_58%]' : 'object-center',
							]}
							pictureAttributes={{
								class:
									articleHero.objectPosition === 'mesa-vidro'
										? 'absolute inset-0 block h-full w-full [&>img]:h-full [&>img]:w-full [&>img]:object-cover [&>img]:object-[center_58%]'
										: 'absolute inset-0 block h-full w-full [&>img]:h-full [&>img]:w-full [&>img]:object-cover [&>img]:object-center',
							}}
						/>
					</div>
					{articleHero.caption ? (
						<figcaption class="mt-3 text-center text-xs leading-relaxed text-on-ink-muted sm:text-sm">
							{articleHero.caption}
						</figcaption>
					) : null}
				</figure>
			) : (
				<div
					class="mt-10 overflow-hidden rounded-2xl shadow-[0_14px_40px_rgba(0,0,0,0.45)] ring-1 ring-white/10"
					aria-hidden="true"
				>
					<div class="aspect-[16/10] w-full bg-gradient-to-br from-brand-900/70 via-brand-900/40 to-ink" />
				</div>
			)
		}
		<div
			class:list={[
				'prose prose-invert prose-lg max-w-none prose-headings:font-display prose-a:text-pop prose-a:underline prose-a:decoration-pop/50 prose-a:decoration-2 prose-a:underline-offset-[0.2em] hover:prose-a:text-accent-hover hover:prose-a:decoration-pop',
				'prose-p:leading-relaxed prose-li:marker:text-pop/80',
				'mt-10 sm:mt-12',
			]}
		>
			<Content />
		</div>

		{
			inlinePairingItems.length ? (
				<EditorialLinks
					class="mt-10"
					eyebrow="Pareamento editorial"
					heading={post.data.category === 'Review' || post.data.category === 'Comparativo'
						? 'Antes de comprar, leia também'
						: 'Para fechar a decisão'}
					items={inlinePairingItems.map((entry) => ({
						href: entry.href,
						label: entry.anchorText,
						description: entry.teaser ?? entry.description,
						tag: entry.editorialLabel ?? entry.kind,
					}))}
				/>
			) : null
		}

		<p class="mt-10 rounded-xl border border-white/10 bg-brand-900/30 px-4 py-3 text-sm leading-relaxed text-on-ink-muted sm:px-5">
			<strong class="text-on-ink-body">Próximo passo comercial (sem pressão):</strong> depois de ler, volte à{' '}
			<a href="/#top-produtos" class="link-accent">lista principal com ofertas</a>
			{' '}ou ao{' '}
			<a href="/melhor-fogao-5-bocas" class="link-accent">guia mestre de fogão 5 bocas</a>
			para cruzar critérios com preço do dia.
		</p>
		{
			faq?.length ? (
				<section class="mt-14 border-t border-white/10 pt-12" aria-labelledby="faq-heading">
					<h2 id="faq-heading" class="font-display text-2xl font-bold tracking-tight text-on-ink-body">
						Perguntas frequentes
					</h2>
					<dl class="mt-8 space-y-8">
						{faq.map((item) => (
							<div>
								<dt class="font-semibold text-on-ink-body">{item.question}</dt>
								<dd class="mt-2 text-base leading-relaxed text-on-ink-muted">{item.answer}</dd>
							</div>
						))}
					</dl>
				</section>
			) : null
		}
		<RelatedContent
			class="mt-14"
			currentPath={Astro.url.pathname}
			excludePaths={[`/blog/${post.id}`, `/blog/${post.id}/`]}
			eyebrow="Veja também"
			title="Leituras relacionadas"
			subtitle="Continue do mesmo cluster — guias, comparativos e artigos editoriais conectados ao tema deste post."
		/>

		<SmartRecommendations
			class="mt-12"
			currentPath={Astro.url.pathname}
			excludePaths={[`/blog/${post.id}`, `/blog/${post.id}/`]}
			heading="Próximos passos editoriais"
		/>
		<p class="mt-12 border-t border-white/10 pt-8 text-sm text-on-ink-muted">
			<a href="/blog" class="text-pop transition hover:text-accent-hover" aria-label="Voltar à listagem do blog">
				← Voltar ao blog
			</a>
		</p>
	</article>
</BaseLayout>
