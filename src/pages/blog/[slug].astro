---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';
import EditorialTrustRibbon from '../../components/EditorialTrustRibbon.astro';
import { getCollection, render } from 'astro:content';
import { PRODUCT_IMAGE_REVIEW } from '../../data/productImages';
import { getBlogThumbnailAsset } from '../../data/blogThumbnailAssets';
import { getImage, Picture } from 'astro:assets';
import blogHeroImage from '../../assets/images/blog/electrolux-cozinha-hero-premium.png';
import melhoresFogoesHeroImage from '../../assets/images/heroes/melhores-fogoes-5-bocas-hero.webp';

const blogHeroAlt =
	'Cozinha moderna com fogão Electrolux de cinco bocas preto com porta de vidro, integrado entre armários escuros e bancada de granito.';
const melhoresFogoesHeroAlt =
	'Melhores fogões 5 bocas em destaque em cozinha planejada moderna, com foco em comparação de modelos e custo-benefício.';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const isMelhoresFogoesPage = post.id === 'melhor-fogao-5-bocas';
const heroImage = isMelhoresFogoesPage ? melhoresFogoesHeroImage : blogHeroImage;
const heroAlt = isMelhoresFogoesPage ? melhoresFogoesHeroAlt : blogHeroAlt;

const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });

const site = Astro.site ?? new URL('https://casapraticaeletro.com.br');
const canonical = new URL(Astro.url.pathname, site).href;
const faq = post.data.faq;

const thumbMeta = getBlogThumbnailAsset(post.id);
let ogImage: string;
if (thumbMeta) {
	const og = await getImage({ src: thumbMeta, width: 1200, format: 'webp' });
	ogImage = og.src.startsWith('http') ? og.src : new URL(og.src.replace(/^\//, ''), site).href;
} else if (post.data.coverImage) {
	ogImage = new URL(String(post.data.coverImage).replace(/^\//, ''), site).href;
} else {
	ogImage = new URL(PRODUCT_IMAGE_REVIEW.brastemp.replace(/^\//, ''), site).href;
}

const orgId = `${site.href}#organization`;
const articleId = `${canonical}#article`;
const webpageId = `${canonical}#webpage`;
const breadcrumbId = `${canonical}#breadcrumb`;
const faqId = `${canonical}#faq`;

const graph: Record<string, unknown>[] = [
	{
		'@type': 'Organization',
		'@id': orgId,
		name: 'Casa Prática Eletro',
		url: site.href,
	},
	{
		'@type': 'BreadcrumbList',
		'@id': breadcrumbId,
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'Início', item: site.href },
			{ '@type': 'ListItem', position: 2, name: 'Blog', item: new URL('/blog/', site).href },
			{ '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
		],
	},
	{
		'@type': 'WebPage',
		'@id': webpageId,
		url: canonical,
		name: `${post.data.title} | Casa Prática Eletro`,
		description: post.data.description,
		mainEntity: { '@id': articleId },
	},
	{
		'@type': 'Article',
		'@id': articleId,
		headline: post.data.title,
		description: post.data.description,
		image: [ogImage],
		author: { '@id': orgId },
		publisher: { '@id': orgId },
		datePublished: post.data.pubDate.toISOString(),
		dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
		mainEntityOfPage: { '@id': webpageId },
		articleSection: post.data.category,
		inLanguage: 'pt-BR',
	},
];
if (faq?.length) {
	graph.push({
		'@type': 'FAQPage',
		'@id': faqId,
		mainEntity: faq.map((item) => ({
			'@type': 'Question',
			name: item.question,
			acceptedAnswer: { '@type': 'Answer', text: item.answer },
		})),
	});
}
const structuredData = { '@context': 'https://schema.org', '@graph': graph };
---

<BaseLayout
	title={`${post.data.title} | Casa Prática Eletro`}
	description={post.data.description}
	canonical={canonical}
	openGraph={{
		title: `${post.data.title} | Casa Prática Eletro`,
		description: post.data.description,
		url: canonical,
		image: ogImage,
		imageAlt: post.data.title,
		type: 'article',
		publishedTime: post.data.pubDate.toISOString(),
		modifiedTime: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
	}}
>
	<script type="application/ld+json" slot="head" set:html={JSON.stringify(structuredData)} />
	<article class="mx-auto max-w-3xl px-4 py-10 sm:px-6 sm:py-12 lg:px-8 lg:py-14">
		<Breadcrumbs
			class="mb-8"
			items={[
				{ name: 'Início', href: '/' },
				{ name: 'Blog', href: '/blog' },
				{ name: post.data.title },
			]}
		/>
		<header>
			<p class="text-xs font-bold uppercase tracking-[0.35em] text-pop">
				{post.data.category} · {fmt.format(post.data.pubDate)}
			</p>
			<h1 class="font-display mt-4 text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl lg:text-5xl">
				{post.data.title}
			</h1>
			<p class="mt-4 text-lg leading-relaxed text-on-ink-body">{post.data.description}</p>
		</header>
		<div class="mt-8">
			<EditorialTrustRibbon />
		</div>
		<figure
			class="mt-10 overflow-hidden rounded-2xl shadow-[0_14px_40px_rgba(0,0,0,0.45)] ring-1 ring-white/10"
		>
			<div class="relative aspect-[16/9] w-full bg-white/5">
				<span class="absolute inset-0 block overflow-hidden">
					<Picture
						src={heroImage}
						alt={heroAlt}
						formats={['avif', 'webp']}
						widths={[640, 768, 960, 1152]}
						sizes="(max-width: 768px) 100vw, 768px"
						quality={80}
						priority
						class="h-full w-full object-cover"
						pictureAttributes={{ class: 'absolute inset-0 block h-full w-full [&>img]:h-full [&>img]:w-full [&>img]:object-cover' }}
					/>
				</span>
			</div>
		</figure>
		<div
			class:list={[
				'prose prose-invert prose-lg max-w-none prose-headings:font-display prose-a:text-pop prose-a:no-underline hover:prose-a:underline',
				'prose-p:leading-relaxed prose-li:marker:text-pop/80',
				'mt-10 sm:mt-12',
			]}
		>
			<Content />
		</div>
		<p class="mt-10 rounded-xl border border-white/10 bg-brand-900/30 px-4 py-3 text-sm leading-relaxed text-on-ink-muted sm:px-5">
			<strong class="text-on-ink-body">Próximo passo comercial (sem pressão):</strong> depois de ler, volte à{' '}
			<a href="/#top-produtos" class="font-semibold text-pop underline-offset-2 hover:underline">lista principal com ofertas</a>
			{' '}ou ao{' '}
			<a href="/melhor-fogao-5-bocas" class="font-semibold text-pop underline-offset-2 hover:underline">guia mestre de fogão 5 bocas</a>
			para cruzar critérios com preço do dia.
		</p>
		{
			faq?.length ? (
				<section class="mt-14 border-t border-white/10 pt-12" aria-labelledby="faq-heading">
					<h2 id="faq-heading" class="font-display text-2xl font-bold tracking-tight text-on-ink-body">
						Perguntas frequentes
					</h2>
					<dl class="mt-8 space-y-8">
						{faq.map((item) => (
							<div>
								<dt class="font-semibold text-on-ink-body">{item.question}</dt>
								<dd class="mt-2 text-base leading-relaxed text-on-ink-muted">{item.answer}</dd>
							</div>
						))}
					</dl>
				</section>
			) : null
		}
		<RelatedArticles
			class="mt-14"
			currentPath={Astro.url.pathname}
			excludePaths={[`/blog/${post.id}`, `/blog/${post.id}/`]}
		/>
		<p class="mt-12 border-t border-white/10 pt-8 text-sm text-on-ink-muted">
			<a href="/blog" class="text-pop transition hover:text-accent-hover" aria-label="Voltar à listagem do blog">
				← Voltar ao blog
			</a>
		</p>
	</article>
</BaseLayout>
