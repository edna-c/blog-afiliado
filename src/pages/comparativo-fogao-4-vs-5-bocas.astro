---
import BaseLayout from '../layouts/BaseLayout.astro';
import RelatedContent from '../components/RelatedContent.astro';
import EditorialLinks from '../components/EditorialLinks.astro';
import SmartRecommendations from '../components/SmartRecommendations.astro';
import EditorialTrustRibbon from '../components/EditorialTrustRibbon.astro';
import { findEntry, type EditorialEntry } from '../data/editorialContent';

const reviewBrastemp = findEntry((e) => e.href === '/review-fogao-5-bocas-brastemp');
const reviewConsul = findEntry((e) => e.href === '/review-fogao-5-bocas-consul');
const reviewElectrolux = findEntry((e) => e.href === '/review-fogao-5-bocas-electrolux');
const guiaCustoBeneficio = findEntry((e) => e.href === '/fogao-5-bocas-custo-beneficio');
const lifestyleEmbutir = findEntry((e) => e.href === '/blog/guia-fogao-embutir-ou-de-piso/');

const reviewItems: EditorialEntry[] = [reviewBrastemp, reviewConsul, reviewElectrolux].filter(Boolean) as EditorialEntry[];
---

<BaseLayout
	title="Fogão 4 ou 5 bocas: qual vale mais a pena em 2026? | Casa Prática Eletro"
	description="Compare fogão 4 e 5 bocas por espaço, rotina, família e custo para decidir qual faz mais sentido na sua cozinha."
>
	<article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<p class="text-xs font-bold uppercase tracking-[0.35em] text-pop">Comparativo</p>
		<h1 class="font-display mt-4 text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl">
			Fogão 4 ou 5 bocas: qual vale mais a pena para sua cozinha?
		</h1>
		<p class="mt-4 text-lg leading-relaxed text-on-ink-body">
			Se você ainda hesita entre <strong class="text-on-ink-body">fogão 4 bocas</strong> e <strong class="text-on-ink-body">5 bocas</strong>, use esta regra: conte
			quantas panelas ficam ligadas ao mesmo tempo em dias normais — não no Natal.
		</p>
		<div class="mt-8">
			<EditorialTrustRibbon />
		</div>
		<div class="table-premium-shell mt-10">
			<table class="table-premium min-w-[520px]">
				<thead>
					<tr>
						<th scope="col">Critério</th>
						<th scope="col">4 bocas</th>
						<th scope="col">5 bocas</th>
					</tr>
				</thead>
				<tbody>
					<tr class="bg-ink">
						<th scope="row" class="font-semibold text-on-ink-body">Uso simultâneo</th>
						<td class="text-on-ink-body">Suficiente na maioria</td>
						<td class="font-medium text-pop">Melhor para quem “lotam” o fogão</td>
					</tr>
					<tr class="bg-brand-900/25">
						<th scope="row" class="font-semibold text-on-ink-body">Espaço</th>
						<td class="text-on-ink-body">Encaixa em cozinhas menores</td>
						<td class="text-on-ink-body">Exige bancada/corredor confortáveis</td>
					</tr>
					<tr class="bg-ink">
						<th scope="row" class="font-semibold text-on-ink-body">Orçamento</th>
						<td class="text-on-ink-body">Normalmente menor</td>
						<td class="text-on-ink-body">Mais bocas ≠ sempre mais caro; compare modelo a modelo</td>
					</tr>
				</tbody>
			</table>
		</div>
		<p class="mt-8 text-base text-on-ink-body">
			Quer ir mais a fundo em texto:{' '}
			<a href="/blog/fogao-4-bocas-ainda-vale-a-pena/" class="font-semibold text-pop underline-offset-2 hover:underline">
				quando o fogão 4 bocas ainda vale a pena
			</a>
			. Para decidir o modelo 5 bocas, volte à{' '}
			<a href="/" class="font-semibold text-pop underline-offset-2 hover:underline" aria-label="Lista de fogões 5 bocas na página inicial">
				lista na página inicial
			</a>
			{' ou ao '}
			<a
				href="/melhor-fogao-5-bocas"
				class="font-semibold text-pop underline-offset-2 hover:underline"
				aria-label="Guia melhor fogão 5 bocas com critérios de compra"
			>
				guia melhor fogão 5 bocas
			</a>
			.
		</p>
		<div class="mt-10 flex flex-wrap gap-4">
			<a
				href="https://example.com/afiliado/fogao-5-bocas"
				class="inline-flex min-h-[48px] items-center justify-center bg-cta px-8 text-xs font-bold uppercase tracking-wider text-white transition hover:bg-cta-hover"
				target="_blank"
				rel="nofollow sponsored noopener noreferrer"
				aria-label="Ver preço atualizado de fogões 5 bocas na loja parceira — abre em nova aba (link patrocinado)"
			>
				Ver preço atualizado — 5 bocas
			</a>
			<a
				href="/como-escolher-fogao-5-bocas"
				class="btn-secondary-premium px-8"
				aria-label="Abrir guia passo a passo: como escolher fogão 5 bocas"
			>
				Ver guia de compra — 5 bocas
			</a>
		</div>

		<RelatedContent
			class="mt-14"
			currentPath="/comparativo-fogao-4-vs-5-bocas"
			eyebrow="Reviews dos modelos citados"
			title="Veja os reviews por marca"
			subtitle="Leituras curtas para confirmar perfil antes de fechar — Brastemp, Consul e Electrolux na mesma faixa."
			items={reviewItems}
			columns={3}
		/>

		<EditorialLinks
			class="mt-12"
			eyebrow="Decisões de ambiente"
			heading="Antes de comprar, alinhe layout e custo-benefício"
			items={[
				...(guiaCustoBeneficio
					? [{
						href: guiaCustoBeneficio.href,
						label: guiaCustoBeneficio.anchorText,
						description: guiaCustoBeneficio.teaser ?? guiaCustoBeneficio.description,
						tag: guiaCustoBeneficio.editorialLabel ?? 'Guia',
					}]
					: []),
				...(lifestyleEmbutir
					? [{
						href: lifestyleEmbutir.href,
						label: lifestyleEmbutir.anchorText,
						description: lifestyleEmbutir.teaser ?? lifestyleEmbutir.description,
						tag: lifestyleEmbutir.editorialLabel ?? 'Lifestyle',
					}]
					: []),
			]}
			variant="stack"
		/>

		<SmartRecommendations
			class="mt-12"
			currentPath="/comparativo-fogao-4-vs-5-bocas"
			heading="Próximos passos editoriais"
		/>
	</article>
</BaseLayout>
