---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRODUCT_IMAGE_REVIEW } from '../data/productImages';

const site = Astro.site ?? new URL('https://casapraticaeletro.com.br');
const canonical = new URL(Astro.url.pathname, site).href;
const pageTitle = 'Sobre a Casa Prática Eletro';
const description =
	'Conheça a Casa Prática Eletro e como criamos reviews e comparativos de eletrodomésticos com foco em compra consciente.';
const ogImage = new URL(PRODUCT_IMAGE_REVIEW.brastemp.replace(/^\//, ''), site).href;
---

<BaseLayout
	title={pageTitle}
	description={description}
	canonical={canonical}
	openGraph={{
		title: pageTitle,
		description,
		url: canonical,
		type: 'website',
		image: ogImage,
		imageAlt: 'Fogão 5 bocas em inox — referência visual Casa Prática Eletro',
	}}
>
	<article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<header>
			<h1 class="font-display text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl">Sobre</h1>
		</header>
		<div class="mt-8 space-y-6 text-base leading-relaxed text-on-ink-body">
			<p>
				Este site existe para ajudar você a escolher melhor fogão 5 bocas com texto direto, comparações e olho no
				custo-benefício.
			</p>
			<p>
				A gente cruza o que compradores costumam dizer nas avaliações, a reputação das marcas e os modelos que mais aparecem
				nas lojas.
			</p>
			<p>
				Queremos só deixar a decisão mais fácil — mostrando opções que costumam fazer sentido para a maioria, sem promessa
				vazia.
			</p>
		</div>
	</article>
</BaseLayout>
