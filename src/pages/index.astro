---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import LogoStrip from '../components/LogoStrip.astro';
import HomeTopProducts from '../components/HomeTopProducts.astro';
import HomeComparisonTable from '../components/HomeComparisonTable.astro';
import HomeGuideSection from '../components/HomeGuideSection.astro';
import BlogGrid from '../components/BlogGrid.astro';
import HomeSeeAlso from '../components/HomeSeeAlso.astro';
import HomeFaqSection from '../components/HomeFaqSection.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const metaDescription =
	'Casa Prática Eletro: reviews, comparativos e guias para escolher fogões e outros eletrodomésticos com mais segurança.';
---

<BaseLayout
	title="Casa Prática Eletro | Reviews e comparativos de eletrodomésticos"
	description={metaDescription}
>
	<Hero />
	<HomeTopProducts />
	<HomeComparisonTable />
	<HomeGuideSection />
	<LogoStrip />
	<BlogGrid
		variant="dark"
		posts={posts}
		title="Atualizações do blog"
		subtitle="Textos para complementar a decisão — reviews e comparativos em linguagem direta, com leitura escaneável e links úteis."
		showViewAllLink={true}
	/>
	<HomeSeeAlso />
	<HomeFaqSection />
</BaseLayout>
