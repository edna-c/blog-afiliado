---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRODUCT_IMAGE_REVIEW } from '../data/productImages';

const site = Astro.site ?? new URL('https://casapraticaeletro.com.br');
const canonical = new URL(Astro.url.pathname, site).href;
const pageTitle = 'Política do Site | Casa Prática Eletro';
const description =
	'Entenda como a Casa Prática Eletro seleciona produtos, atualiza comparativos e mantém recomendações úteis para o consumidor.';
const ogImage = new URL(PRODUCT_IMAGE_REVIEW.brastemp.replace(/^\//, ''), site).href;
---

<BaseLayout
	title={pageTitle}
	description={description}
	canonical={canonical}
	openGraph={{
		title: pageTitle,
		description,
		url: canonical,
		type: 'website',
		image: ogImage,
		imageAlt: 'Fogão 5 bocas em inox — referência visual Casa Prática Eletro',
	}}
>
	<article class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
		<header>
			<h1 class="font-display text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl">Política do Site</h1>
		</header>
		<div class="mt-8 space-y-6 text-base leading-relaxed text-on-ink-body">
			<p>
				A Casa Prática Eletro existe para ajudar você a escolher eletrodomésticos com mais segurança, usando comparativos
				práticos e linguagem simples.
			</p>
			<p>As indicações de produtos são revisadas com frequência para manter preço, disponibilidade e contexto de uso atualizados.</p>
			<p>
				Nossa curadoria considera avaliações de compradores, reputação de marca e critérios de custo-benefício no dia a dia.
			</p>
			<p>Nosso foco é recomendar o que realmente faz sentido para sua casa, sem promessas exageradas.</p>
		</div>
	</article>
</BaseLayout>
