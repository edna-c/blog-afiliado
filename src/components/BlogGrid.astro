---
import type { CollectionEntry } from 'astro:content';
import { Picture } from 'astro:assets';
import blogHeroImage from '../assets/blog/blog-hero-electrolux-cozinha.png';

const blogHeroAlt =
	'Cozinha moderna com fogão Electrolux de cinco bocas preto com porta de vidro, integrado entre armários escuros e bancada de granito.';

const thumbShadow = 'shadow-[0_10px_30px_rgba(0,0,0,0.4)]';

interface Props {
	posts: CollectionEntry<'blog'>[];
	title?: string;
	subtitle?: string;
	showViewAllLink?: boolean;
}

const {
	posts,
	title = 'Artigos recentes',
	subtitle = 'Textos e comparativos para ajudar na hora de escolher fogão.',
	showViewAllLink = true,
} = Astro.props;

const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'short', year: 'numeric' });
---

<section class="bg-white py-20 lg:py-28" aria-labelledby="blog-grid-heading">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mx-auto max-w-2xl text-center">
			<p class="text-sm font-semibold uppercase tracking-widest text-accent-on-light">Artigos</p>
			<h2 id="blog-grid-heading" class="font-display mt-2 text-3xl font-bold text-brand-900 sm:text-4xl">{title}</h2>
			<p class="mt-3 text-neutral-700">{subtitle}</p>
		</div>
		<div class="mt-14 grid gap-8 md:grid-cols-2 lg:grid-cols-3">
			{posts.map((post, index) => (
				<article class="group flex flex-col overflow-hidden rounded-2xl bg-neutral-50 ring-1 ring-black/5 transition hover:shadow-lg">
					<a
						href={`/blog/${post.id}/`}
						class:list={[
							'relative block aspect-[16/10] overflow-hidden rounded-[12px] bg-neutral-200',
							index === 0 && thumbShadow,
						]}
						aria-label={`Abrir artigo no blog: ${post.data.title}`}
					>
						{index === 0 ? (
							<span class="absolute inset-0 block overflow-hidden">
								<Picture
									src={blogHeroImage}
									alt=""
									formats={['avif', 'webp']}
									widths={[400, 560, 720, 960]}
									sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
									quality={78}
									class="h-full w-full object-cover"
									pictureAttributes={{ class: 'absolute inset-0 block h-full w-full [&>img]:h-full [&>img]:w-full [&>img]:object-cover' }}
								/>
							</span>
						) : (
							<div class="h-full w-full bg-neutral-300/90" aria-hidden="true" />
						)}
					</a>
					<div class="flex flex-1 flex-col p-6">
						<p class="text-xs font-medium uppercase tracking-wide text-neutral-600">
							{post.data.category} · {fmt.format(post.data.pubDate)}
						</p>
						<h3 class="font-display mt-2 text-lg font-semibold leading-snug text-brand-900">
							<a href={`/blog/${post.id}/`} class="hover:text-accent-on-light-hover">
								{post.data.title}
							</a>
						</h3>
						<p class="mt-2 line-clamp-2 flex-1 text-sm text-neutral-700">{post.data.description}</p>
						<a
							href={`/blog/${post.id}/`}
							class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-accent-on-light underline decoration-pop/70 decoration-2 underline-offset-4 hover:text-accent-on-light-hover hover:decoration-pop"
							aria-label={`Ver artigo completo no blog: ${post.data.title}`}
						>
							Ver artigo completo
							<span aria-hidden="true">→</span>
						</a>
					</div>
				</article>
			))}
		</div>
		{showViewAllLink && (
			<div class="mt-12 text-center">
				<a
					href="/blog"
					class="inline-flex rounded-full border border-brand-900/15 px-6 py-3 text-sm font-semibold text-brand-900 transition hover:border-brand-900/30 hover:bg-neutral-50"
					aria-label="Ver todos os artigos e guias no blog"
				>
					Ver todos os artigos no blog
				</a>
			</div>
		)}
	</div>
</section>
