---
const nav = [
	{ href: '/', label: 'Início' },
	{ href: '/sobre', label: 'Sobre' },
	{ href: '/blog', label: 'Blog' },
	{ href: '/contato', label: 'Contato' },
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-ink/85 backdrop-blur-xl">
	<div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
		<a href="/" class="group font-display text-lg font-extrabold tracking-tight sm:text-xl">
			<span class="text-white">AFFILIATE</span>
			<span class="ml-1 text-pop transition group-hover:text-accent-hover">PRO</span>
		</a>
		<nav class="hidden items-center gap-8 text-xs font-semibold uppercase tracking-[0.2em] text-white/55 md:flex" aria-label="Principal">
			{nav.map((item) => (
				<a href={item.href} class="transition hover:text-pop">
					{item.label}
				</a>
			))}
		</nav>
		<a
			href="/contato"
			class="ring-pop rounded-none bg-pop px-5 py-2.5 text-xs font-bold uppercase tracking-wider text-ink transition hover:bg-accent-hover"
		>
			Fale conosco
		</a>
	</div>
</header>
