---
export interface BreadcrumbItem {
	name: string;
	href?: string;
}

interface Props {
	items: BreadcrumbItem[];
	class?: string;
}

const { items, class: className } = Astro.props;
---

<nav class:list={['text-on-ink-muted', className]} aria-label="Navegação estrutural (breadcrumb)">
	<ol class="flex flex-wrap items-center gap-x-1.5 gap-y-1 text-xs sm:text-sm">
		{
			items.map((item, index) => (
				<li class="flex min-w-0 items-center gap-x-1.5">
					{index > 0 ? (
						<span class="shrink-0 text-on-ink-muted/70" aria-hidden="true">
							/
						</span>
					) : null}
					{item.href ? (
						<a
							href={item.href}
							class="truncate font-medium text-pop underline-offset-2 transition hover:text-accent-hover hover:underline"
						>
							{item.name}
						</a>
					) : (
						<span class="truncate font-semibold text-on-ink-body">{item.name}</span>
					)}
				</li>
			))
		}
	</ol>
</nav>
