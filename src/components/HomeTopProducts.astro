---
export interface Product {
	name: string;
	tagline: string;
	highlight: string;
	benefits: string[];
	proofLine: string;
	reviewSlug: string;
	offerUrl: string;
	shopeeUrl: string;
}

const products: Product[] = [
	{
		name: 'Brastemp BFS5NCR',
		tagline: 'Melhor custo-benefício',
		highlight:
			'Perfeito para quem quer um fogão confiável no dia a dia, com bom espaço no forno e chama forte. 👉 Ideal para famílias ou quem cozinha com frequência.',
		benefits: ['Segurança em cada boca', 'Forno que cabe o que você usa no dia a dia', 'Fácil de achar peça quando precisa'],
		proofLine: '✔ Um dos mais escolhidos para uso diário em 2026',
		reviewSlug: 'brastemp',
		offerUrl: 'https://example.com/afiliado/brastemp-bfs5ncr',
		shopeeUrl: 'https://s.shopee.com.br/2qQVdcWHwK',
	},
	{
		name: 'Consul CFS5NAB',
		tagline: 'Entrada sólida',
		highlight:
			'Ótima escolha para quem quer economizar sem abrir mão do básico bem feito. 👉 Simples, funcional e resolve bem o dia a dia.',
		benefits: ['Sem complicação na rotina', 'Boa para cozinha média', 'Preço honesto pelo que entrega'],
		proofLine: '✔ Caminho firme para quem quer gastar menos sem susto',
		reviewSlug: 'consul',
		offerUrl: 'https://example.com/afiliado/consul-cfs5nab',
		shopeeUrl: 'https://example.com/afiliado/shopee/consul-cfs5nab',
	},
	{
		name: 'Electrolux 76USQ',
		tagline: 'Mais recursos',
		highlight:
			'Linha com mais recursos e acabamento caprichado — bom para quem cozinha bastante e quer forno e mesa com “cara” de cozinha arrumada. 👉 Indicado para quem usa o fogão pesado no dia a dia.',
		benefits: ['Acabamento que valoriza a cozinha', 'Forno com funções a mais (varia por modelo)', 'Pra quem cozinha pesado e quer folga'],
		proofLine: '✔ Entre os que analisamos, é o que mais soma recursos e acabamento',
		reviewSlug: 'electrolux',
		offerUrl: 'https://example.com/afiliado/electrolux-76usq',
		shopeeUrl: 'https://example.com/afiliado/shopee/electrolux-76usq',
	},
];
---

<section id="top-produtos" class="scroll-mt-24 border-b border-white/10 bg-brand-900/40 py-16 lg:py-20">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl">
			<p class="text-xs font-bold uppercase tracking-[0.35em] text-pop">Escolha rápida</p>
			<h2 class="font-display mt-3 text-3xl font-extrabold tracking-tight text-white sm:text-4xl">
				Lista dos melhores modelos — comparativo direto
			</h2>
			<p class="mt-3 text-sm text-white/55">
				Alguns links podem gerar ganhos para o site, sem custo para você. Preço muda o tempo todo — confira sempre na hora de comprar.
			</p>
		</div>
		<div class="mt-12 grid gap-6 lg:grid-cols-3">
			{
				products.map((p) => (
					<article class="flex flex-col border border-white/10 bg-ink/80 p-6 ring-1 ring-white/5 transition hover:border-pop/35 hover:ring-pop/20">
						<p class="text-[10px] font-bold uppercase tracking-[0.25em] text-pop">{p.tagline}</p>
						<h3 class="font-display mt-3 text-xl font-bold text-white">{p.name}</h3>
						<p class="mt-2 text-sm text-white/60">
							{p.highlight}{' '}
							<a
								href={`/review-fogao-5-bocas-${p.reviewSlug}`}
								class="font-semibold text-pop underline-offset-2 hover:underline"
							>
								Ver avaliação completa
							</a>
							.
						</p>
						<ul class="mt-4 list-inside list-disc space-y-1.5 text-sm text-white/70">
							{p.benefits.map((b) => (
								<li>{b}</li>
							))}
						</ul>
						<div class="mt-8 flex flex-col gap-3 sm:flex-row sm:items-center">
							<a
								href={p.name === 'Brastemp BFS5NCR' ? 'https://meli.la/1SRkvTs' : p.offerUrl}
								class="inline-flex min-h-[48px] flex-1 items-center justify-center bg-pop px-5 text-center text-xs font-bold uppercase tracking-wider text-ink transition hover:bg-accent-hover"
								target={p.name === 'Brastemp BFS5NCR' ? '_blank' : undefined}
								rel="nofollow sponsored noopener"
							>
								🔥 Ver preço no Mercado Livre
							</a>
							<a
								href={p.shopeeUrl}
								class="inline-flex min-h-[48px] flex-1 items-center justify-center border border-white/20 px-5 text-center text-xs font-bold uppercase tracking-wider text-white transition hover:border-pop hover:text-pop"
								target={p.name === 'Brastemp BFS5NCR' ? '_blank' : undefined}
								rel="nofollow sponsored noopener"
							>
								🛒 Ver mais barato na Shopee
							</a>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
