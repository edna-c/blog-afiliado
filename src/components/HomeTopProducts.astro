---
import { produtos } from '../data/products';
import type { AstroRasterImport } from '../types/astro-image';
import brastempCardImage from '../assets/images/cards/brastemp-bfs5ncr-card-premium.webp';
import consulCardImage from '../assets/images/cards/consul-fe5ig-card-premium.webp';
import electroluxCardImage from '../assets/images/cards/electrolux-cfs5nab-card-premium.webp';

export type ProductBadgeTone = 'emerald' | 'amber' | 'pop';

export interface Product {
	name: string;
	badge: string;
	badgeTone: ProductBadgeTone;
	basePrice: string;
	benefits: string[];
	socialProof: string;
	reviewSlug: string;
	mercadoLivreUrl: string;
	shopeeUrl?: string;
	/** Rótulos opcionais dos CTAs de loja (só onde o copy for específico). */
	mlCtaText?: string;
	shopeeCtaText?: string;
	image?: string | AstroRasterImport;
	/** Escala fina (contain) só quando a arte desequilibra altura vs. os outros cards. */
	imageVisualScale?: number;
	imageAlt?: string;
	/** Destaque principal (melhor custo-benefício): card e CTA reforçados */
	featured?: boolean;
}

const products: Product[] = [
	{
		name: 'Brastemp BFS5NCR',
		badge: '🏆 Melhor custo-benefício',
		badgeTone: 'emerald',
		basePrice: 'R$ 1.672',
		benefits: [
			'Boa potência para uso diário',
			'Forno espaçoso para o rotineiro',
			'Fácil limpeza e manutenção básica',
			'Ótimo custo-benefício',
		],
		socialProof: '⭐ 4,7/5 baseado em avaliações',
		reviewSlug: 'brastemp',
		mercadoLivreUrl: produtos.brastempBFS5NCR.ml,
		shopeeUrl: produtos.brastempBFS5NCR.shopee,
		image: brastempCardImage,
		imageAlt: 'Fogão a gás Brastemp BFS5NCR cinco bocas em inox',
		featured: true,
	},
	{
		name: 'Consul CFS5NAB',
		badge: '🔥 Mais vendido',
		badgeTone: 'amber',
		basePrice: 'R$ 1.580',
		benefits: [
			'Simples e confiável no dia a dia',
			'Boa para cozinha média',
			'Preço honesto pelo que entrega',
			'Fácil de usar sem firula',
		],
		socialProof: '✔ Mais de 1.000 avaliações',
		reviewSlug: 'consul',
		mercadoLivreUrl: produtos.consulCFS5NAB.ml,
		shopeeUrl: produtos.consulCFS5NAB.shopee,
		mlCtaText: 'VER PREÇO NO MERCADO LIVRE',
		shopeeCtaText: 'VER OFERTA NA SHOPEE',
		image: consulCardImage,
		imageVisualScale: 1.065,
		imageAlt: 'Fogão a gás Consul CFS5NAB cinco bocas em inox com tampa de vidro',
	},
	{
		name: 'Electrolux FE5IG',
		badge: '⭐ Melhor geral',
		badgeTone: 'pop',
		basePrice: 'R$ 1.899',
		benefits: [
			'Acabamento que valoriza a cozinha',
			'Forno com mais recursos (varia por modelo)',
			'Ideal para quem cozinha pesado',
			'Mesa em inox com visual premium',
		],
		socialProof: '⭐ 4,6/5 baseado em avaliações',
		reviewSlug: 'electrolux',
		mercadoLivreUrl: produtos.electroluxFE5IG.ml,
		mlCtaText: 'VER PREÇO NO MERCADO LIVRE',
		image: electroluxCardImage,
		imageAlt: 'Fogão a gás Electrolux FE5IG PerfectCook cinco bocas em inox com mesa em inox',
	},
];

const badgeToneClass: Record<ProductBadgeTone, string> = {
	emerald:
		'border-b border-emerald-950/50 bg-emerald-950/92 text-emerald-50/95 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] ring-1 ring-emerald-500/15',
	amber:
		'border-b border-amber-900/35 bg-amber-700/88 text-amber-50/95 shadow-[inset_0_1px_0_rgba(255,255,255,0.1)] ring-1 ring-amber-400/22',
	pop: 'border-b border-white/[0.06] bg-zinc-900/95 text-pop/90 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] ring-1 ring-white/10',
};

const imageSrc = (img: NonNullable<Product['image']>) => (typeof img === 'string' ? img : img.src);
const imageWidth = (img: NonNullable<Product['image']>) => (typeof img === 'string' ? 800 : img.width);
const imageHeight = (img: NonNullable<Product['image']>) => (typeof img === 'string' ? 800 : img.height);
---

<section
	id="top-produtos"
	class="scroll-mt-24 border-b border-white/10 bg-brand-900/40 py-16 sm:py-20 lg:py-24"
	aria-labelledby="top-produtos-heading"
>
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="max-w-3xl">
			<p class="text-xs font-bold uppercase tracking-[0.35em] text-pop">Escolha rápida</p>
			<h2 id="top-produtos-heading" class="font-display mt-3 text-3xl font-extrabold tracking-tight text-on-ink-body sm:text-4xl">
				Lista dos melhores modelos — comparativo direto
			</h2>
			<p class="mt-3 text-sm text-on-ink-body">
				Alguns links podem gerar comissão para o site, sem custo para você. Os preços podem variar, então vale conferir no momento da
				compra. Quer entender os critérios da seleção? Veja o{' '}
				<a href="/melhor-fogao-5-bocas" class="font-semibold text-pop underline-offset-2 hover:underline">
					guia de melhor fogão 5 bocas
				</a>
				. Se preferir um passo a passo, acesse também o{' '}
				<a href="/como-escolher-fogao-5-bocas" class="font-semibold text-pop underline-offset-2 hover:underline">
					guia de compra completo
				</a>
				.
			</p>
			<p class="mt-3 text-sm font-semibold text-on-ink-body">
				Agora veja os modelos mais vendidos, <strong class="font-semibold text-on-ink-body">ofertas atualizadas hoje</strong> — estoque pode
				variar; use os botões para <strong class="font-semibold text-on-ink-body">ver disponibilidade</strong> na loja.
			</p>
		</div>
		<div class="mt-14 grid grid-cols-1 items-stretch gap-6 md:grid-cols-3 md:gap-6">
			{
				products.map((p) => (
					<article
						class:list={[
							'flex h-full min-h-0 flex-col overflow-hidden rounded-2xl border border-white/[0.09] bg-ink/80 shadow-[0_10px_36px_-22px_rgba(0,0,0,0.58)] ring-1 ring-white/[0.045] transition-[box-shadow,border-color,background-color] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] hover:border-white/[0.11] hover:bg-ink/[0.84] hover:shadow-[0_14px_40px_-24px_rgba(0,0,0,0.56)]',
							p.featured
								? 'relative z-[1]'
								: '',
						]}
					>
						<div
							class:list={[
								'flex shrink-0 items-center justify-center px-4 text-center font-semibold leading-snug tracking-[0.04em] sm:tracking-[0.055em]',
								'py-3 text-[0.8125rem] sm:text-sm',
								p.featured
									? 'border-b border-emerald-950/45 bg-emerald-950/92 text-emerald-50/95 shadow-[inset_0_1px_0_rgba(255,255,255,0.06)] ring-1 ring-emerald-500/18'
									: badgeToneClass[p.badgeTone],
							]}
						>
							{p.badge}
						</div>

						{p.image ? (
							<div class="product-media-area shrink-0">
								<div
									class="product-media-frame relative aspect-square w-full max-w-[min(100%,21.5rem)] overflow-hidden rounded-[0.875rem] bg-[#151515]"
								>
									<div class="absolute inset-3 flex items-center justify-center sm:inset-[0.8125rem]">
										<img
											class:list={[
												'max-h-full max-w-full object-contain object-center',
												p.reviewSlug === 'electrolux' &&
													'brightness-[1.03] contrast-[1.06] saturate-[1.02]',
											]}
											style={
												p.imageVisualScale && p.imageVisualScale !== 1
													? {
															transform: `scale(${p.imageVisualScale})`,
															transformOrigin: 'center center',
														}
													: undefined
											}
											src={imageSrc(p.image)}
											alt={p.imageAlt ?? ''}
											width={imageWidth(p.image)}
											height={imageHeight(p.image)}
											loading="lazy"
											decoding="async"
										/>
									</div>
								</div>
							</div>
						) : null}

						<div class="flex min-h-0 flex-1 flex-col px-5 pb-5 pt-[calc(1.25rem+3px)] sm:px-6 sm:pb-6">
							<h3 class="font-display text-xl font-bold leading-snug tracking-tight text-on-ink-body sm:text-[1.35rem]">
								{p.name}
							</h3>
							<p class="mt-2.5 text-sm font-medium leading-snug text-on-ink-muted">
								A partir de{' '}
								<span class="home-product-price-value font-extrabold tracking-wide text-cta">
									{p.basePrice}
								</span>
							</p>

							<ul class="mt-3.5 space-y-2 text-sm leading-snug text-on-ink-list">
								{p.benefits.map((b) => (
									<li class="flex gap-2.5">
										<span class="mt-0.5 shrink-0 text-on-ink-list" aria-hidden="true">
											•
										</span>
										<span>{b}</span>
									</li>
								))}
							</ul>

							<p class="mt-3 text-sm font-semibold text-on-ink-body">{p.socialProof}</p>

							<div class="mt-auto flex flex-col gap-3 border-t border-white/[0.06] pt-5">
								<div class="grid grid-cols-1 gap-2.5 sm:grid-cols-2 sm:gap-3">
									<a
										href={p.mercadoLivreUrl}
										class:list={[
											'inline-flex min-h-[52px] w-full items-center justify-center gap-1.5 rounded-[0.625rem] border-2 border-transparent px-5 py-3.5 text-center text-[0.75rem] font-extrabold uppercase tracking-wide text-white transition-[box-shadow,background-color,filter,border-color] duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] sm:text-[0.72rem]',
											p.featured
												? 'border-emerald-400/25 bg-emerald-700 shadow-[0_1px_0_rgba(255,255,255,0.08)_inset,0_2px_8px_-2px_rgba(0,0,0,0.35),0_8px_24px_-8px_rgba(5,150,105,0.38)] ring-1 ring-emerald-300/25 hover:border-emerald-300/35 hover:bg-emerald-600 hover:shadow-[0_1px_0_rgba(255,255,255,0.1)_inset,0_4px_14px_-4px_rgba(0,0,0,0.38),0_12px_32px_-10px_rgba(5,150,105,0.42)] hover:brightness-[1.02] active:brightness-[0.98]'
												: 'border-white/10 bg-cta shadow-[0_1px_0_rgba(255,255,255,0.12)_inset,0_2px_8px_-2px_rgba(0,0,0,0.35),0_6px_20px_-8px_rgba(34,197,94,0.32)] ring-1 ring-white/18 hover:border-white/18 hover:bg-cta-hover hover:shadow-[0_1px_0_rgba(255,255,255,0.14)_inset,0_4px_14px_-4px_rgba(0,0,0,0.36),0_10px_28px_-8px_rgba(34,197,94,0.38)] hover:brightness-[1.02] active:brightness-[0.99]',
											!p.shopeeUrl && 'sm:col-span-2',
										]}
										target="_blank"
										rel="noopener noreferrer nofollow sponsored"
										aria-label={`Ver preço e disponibilidade do fogão ${p.name} no Mercado Livre — abre em nova aba`}
									>
										{p.featured ? (
											<span class="inline-flex items-center gap-1.5">
												<span aria-hidden="true">🔥</span>
												<span>VER MELHOR PREÇO</span>
											</span>
										) : (
											<span class="inline-flex items-center gap-1.5">
												<span aria-hidden="true">👉</span>
												<span>{p.mlCtaText ?? 'Ver preço no Mercado Livre'}</span>
											</span>
										)}
									</a>
									{p.shopeeUrl ? (
										<a
											href={p.shopeeUrl}
											class="btn-secondary-premium w-full px-5 py-3.5 text-[0.72rem] sm:text-[0.72rem]"
											target="_blank"
											rel="noopener noreferrer nofollow sponsored"
											aria-label={`Ver oferta do fogão ${p.name} na Shopee — abre em nova aba (link patrocinado)`}
										>
											<span aria-hidden="true">👉</span>
											{p.shopeeCtaText ?? 'Ver oferta na Shopee'}
										</a>
									) : null}
								</div>
								<a
									href={`/review-fogao-5-bocas-${p.reviewSlug}`}
									class="btn-secondary-premium w-full !normal-case px-5 py-3.5 text-[0.8125rem] font-bold tracking-normal"
									aria-label={`Ver análise completa do fogão ${p.name}`}
								>
									<span aria-hidden="true">👉</span>
									Ver análise completa
								</a>
								<ul class="space-y-1 border-t border-white/10 pt-3 text-[11px] leading-relaxed text-on-ink-muted sm:text-xs">
									<li>✔ Ofertas atualizadas hoje</li>
									<li>✔ Frete pode variar por região</li>
									<li>✔ Estoque pode variar — ver disponibilidade na loja</li>
								</ul>
							</div>
						</div>
					</article>
				))
			}
		</div>
	</div>
</section>
