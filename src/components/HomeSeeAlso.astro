---
/**
 * HomeSeeAlso — hub editorial discreto da home.
 *
 * Curadoria fixa: 4 entradas representando guia, comparativo, análise longa
 * e leitura lifestyle (decoração / cozinha moderna). Mantém a estética
 * dark premium da home; links naturais, sem cara de bloco de afiliado.
 */
import { findEntry, type EditorialEntry } from '../data/editorialContent';

const guia = findEntry((e) => e.href === '/melhor-fogao-5-bocas');
const reviewBrastemp = findEntry((e) => e.href === '/review-fogao-5-bocas-brastemp');
const reviewConsul = findEntry((e) => e.href === '/review-fogao-5-bocas-consul');
const reviewElectrolux = findEntry((e) => e.href === '/review-fogao-5-bocas-electrolux');
const comparativo = findEntry((e) => e.href === '/comparativo-fogao-4-vs-5-bocas');
const analiseBrastemp = findEntry((e) => e.href === '/brastemp-bfs5ncr-vale-a-pena');

/** Hub visível: guia pilar + três reviews da curadoria. */
const cards: EditorialEntry[] = [guia, reviewBrastemp, reviewConsul, reviewElectrolux].filter(
	Boolean,
) as EditorialEntry[];
---

<section class="bg-ink py-16 lg:py-20" aria-labelledby="see-also-heading">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<p class="text-[10px] font-bold uppercase tracking-[0.32em] text-pop sm:text-[11px]">
			Hub editorial
		</p>
		<h2
			id="see-also-heading"
			class="font-display mt-2 text-2xl font-extrabold tracking-tight text-on-ink-body sm:text-3xl"
		>
			Veja também
		</h2>
		<p class="mt-3 max-w-2xl text-sm leading-relaxed text-on-ink-body sm:text-base">
			{guia ? (
				<>
					Para decidir com calma, comece pelo{' '}
					<a
						href={guia.href}
						class="font-semibold text-on-ink-body underline decoration-pop/40 decoration-[1.5px] underline-offset-[5px] transition hover:text-pop hover:decoration-pop"
					>
						melhor fogão 5 bocas
					</a>
				</>
			) : null}
			{comparativo ? (
				<>
					{' '}
					— ou feche o tamanho certo no{' '}
					<a
						href={comparativo.href}
						class="font-semibold text-on-ink-body underline decoration-pop/40 decoration-[1.5px] underline-offset-[5px] transition hover:text-pop hover:decoration-pop"
					>
						comparativo 4 vs 5 bocas
					</a>
				</>
			) : null}
			. Os cards abaixo levam às{' '}
			<strong class="font-semibold text-on-ink-body">reviews por marca</strong> (Brastemp, Consul e Electrolux).
			{analiseBrastemp ? (
				<>
					{' '}
					Quem quiser texto longo com FAQ pode abrir a{' '}
					<a
						href={analiseBrastemp.href}
						class="font-semibold text-on-ink-body underline decoration-pop/40 decoration-[1.5px] underline-offset-[5px] transition hover:text-pop hover:decoration-pop"
					>
						análise completa Brastemp BFS5NCR
					</a>
					.
				</>
			) : (
				'.'
			)}
		</p>

		<ul class="mt-8 grid gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-4">
			{cards.map((card) => (
				<li>
					<a
						href={card.href}
						class="group flex h-full flex-col justify-between rounded-2xl border border-white/10 bg-brand-900/40 p-5 ring-1 ring-white/5 transition duration-300 ease-out hover:-translate-y-0.5 hover:border-pop/35 hover:bg-brand-900/60 hover:ring-white/10 sm:p-6"
					>
						<span class="inline-flex w-fit max-w-full rounded-full border border-white/15 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider text-on-ink-muted">
							{card.editorialLabel ?? card.kind}
						</span>
						<span class="font-display mt-3 text-base font-bold leading-snug text-on-ink-body transition group-hover:text-pop sm:text-lg">
							{card.title}
						</span>
						<span class="mt-2 line-clamp-2 text-xs leading-relaxed text-on-ink-muted sm:text-sm">
							{card.teaser ?? card.description}
						</span>
						<span class="mt-4 inline-flex items-center gap-1 text-[11px] font-bold uppercase tracking-wider text-pop">
							Abrir
							<span aria-hidden="true" class="transition-transform group-hover:translate-x-0.5">→</span>
						</span>
					</a>
				</li>
			))}
		</ul>

		<div class="mt-12 max-w-2xl border-t border-white/10 pt-10">
			<p class="text-sm font-medium text-on-ink-body">
				Pronto para cruzar tudo com preço de hoje? Volte à lista principal e confira disponibilidade na hora.
			</p>
			<p class="mt-4">
				<a
					href="#top-produtos"
					class="inline-flex min-h-[48px] items-center justify-center bg-cta px-8 text-xs font-bold uppercase tracking-wider text-white transition hover:bg-cta-hover"
					aria-label="Ver preços atualizados dos melhores fogões 5 bocas na lista principal"
				>
					👉 Ver preços atualizados dos melhores fogões agora
				</a>
			</p>
		</div>
	</div>
</section>
