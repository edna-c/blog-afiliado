---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Affiliate Pro',
	description = 'Análises honestas, comparativos e guias para escolher fogão com segurança — linguagem clara e aviso quando há link patrocinado.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="bg-ink">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="flex min-h-screen flex-col bg-ink text-white">
		<Header />
		<main class="flex-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>
