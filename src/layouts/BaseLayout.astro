---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Casa Prática Eletro',
	description = 'Casa Prática Eletro traz reviews, comparativos e guias de eletrodomésticos para ajudar você a comprar com confiança.',
} = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="bg-ink">
	<head>
		<meta charset="utf-8" />
		<meta name="google-site-verification" content="d2lMKfceWMXDWWV4xm89oczf4SFfBRt22BiNdR7Ik-E" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="flex min-h-screen flex-col bg-ink text-on-ink-body">
		<a href="#conteudo-principal" class="skip-link">Pular para o conteúdo principal</a>
		<Header />
		<main id="conteudo-principal" class="flex-1" tabindex="-1">
			<slot />
		</main>
		<Footer />
	</body>
</html>
