# Copie para `.env` local ou defina na Vercel (Environment Variables).
# Variáveis com prefixo PUBLIC_ são expostas ao cliente em build (Astro).

# Opcional: sobrescreve o e-mail por defeito em /contato (mailto e texto visível).
# Se omitir, usa-se casapraticaeletro@gmail.com definido em `src/data/siteContact.ts`.
PUBLIC_CONTACT_EMAIL=casapraticaeletro@gmail.com
